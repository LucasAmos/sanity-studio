{
  "version": "1.24.0",
  "name": "sanity-studio",
  "main": "index.js",
  "repository": "https://github.com/LucasAmos/sanity-studio.git",
  "author": "Lucas Amos <9055266+LucasAmos@users.noreply.github.com>",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "studio",
    "apps/*"
  ],
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint:fix": "oxlint --fix",
    "lint": "oxlint",
    "release": "yarn workspace @lucasamos/sanity-studio release && yarn release-it --ci",
    "release:dry-run": "yarn workspace @lucasamos/sanity-studio release:dry-run && yarn release-it --ci --dry-run"
  },
  "devDependencies": {
    "@release-it-plugins/workspaces": "^5.0.3",
    "@release-it/conventional-changelog": "^11.0.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "release-it": "^20.2.0"
  },
  "packageManager": "yarn@4.13.0",
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0"
  }
}
